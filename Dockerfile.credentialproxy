# Build Go binary
FROM golang:1.26-trixie AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o credentialproxy ./cmd/credentialproxy

# Runtime image (hardened: non-root, read-only rootfs)
FROM debian:trixie-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*
RUN groupadd -g 65532 nonroot && useradd -u 65532 -g 65532 -s /usr/sbin/nologin nonroot
COPY --from=builder /app/credentialproxy /usr/local/bin/credentialproxy
USER 65532:65532
EXPOSE 8083
ENTRYPOINT ["credentialproxy"]
